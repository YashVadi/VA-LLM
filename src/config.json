{
  "training_config": {
    "learning_rate": 1e-4,
    "warmup_steps": 100,
    "epochs": 10,
    "early_stopping": 5,
    "weight_decay": 0,
    "batch_size": 8
  },

  "data_config": {
    "image_data_root": "data/images",
    "caption_data_path": "data/captions.txt",
    "test_size": 0.2
  },

  "logging_config": {
    "project_name": "image-captioning",
    "ckpt_dir": "./",
    "ckpt_freq": 1500,
    "save_model_path": "best_model.pth"
  },

  "model_config": {
    "num_attn_heads": 8,
    "layer_connections": [[6,6], [10,10]],
    "anchor_model": "gpt2",
    "augmenting_model": "openai/clip-vit-base-patch32",
    "anchor_output_weight": 1,
    "augment_output_weight": 1,
    "freeze_anchor_params": true,
    "freeze_augment_params": true
  }
}